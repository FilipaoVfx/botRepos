# ─── Supabase ────────────────────────────────────────────────────────
# Panel Supabase → Project Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# Usa la SERVICE_ROLE key (server-side, nunca en el cliente).
# Si solo tienes la anon key, el bot funciona en lectura pero la ingesta puede fallar por RLS.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...
# Opcional (fallback si no hay service role)
# SUPABASE_ANON_KEY=eyJhbGciOi...

# ─── Pinecone ────────────────────────────────────────────────────────
# https://app.pinecone.io → API Keys
PINECONE_API_KEY=pcsk_xxxxxxxx
# Nombre del índice (dimensión 1536, métrica cosine). Default: indexbook-knowledge
PINECONE_INDEX=indexbook-knowledge

# ─── OpenAI ──────────────────────────────────────────────────────────
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxx
# Modelo de embeddings. text-embedding-3-small = 1536 dims (default)
# text-embedding-3-large = 3072 dims (requiere recrear el índice Pinecone)
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ─── Telegram ────────────────────────────────────────────────────────
# Crea el bot con @BotFather y pega el token aquí
TELEGRAM_BOT_TOKEN=123456789:ABC-DEF...
